{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "Rate Limit Configuration Schema",
    "type": "object",
    "properties": {
        "permissions": {
            "type": "object",
            "patternProperties": {
                "^default$": {
                    "type": "object",
                    "properties": {
                        "models": {
                            "type": "object",
                            "patternProperties": {
                                "^[a-zA-Z0-9.\\-:]+$": {
                                    "type": "object",
                                    "properties": {
                                        "rpm": {
                                            "type": "integer",
                                            "not": {
                                                "const": 0
                                            },
                                            "minimum": -1,
                                            "description": "Requests per minute (-1 for unlimited)"
                                        },
                                        "tpm": {
                                            "type": "integer",
                                            "not": {
                                                "const": 0
                                            },
                                            "minimum": -1,
                                            "description": "Tokens per minute (-1 for unlimited)"
                                        }
                                    },
                                    "required": [
                                        "rpm",
                                        "tpm"
                                    ],
                                    "additionalProperties": false
                                }
                            },
                            "additionalProperties": false
                        },
                        "accounts": {
                            "type": "array",
                            "items": {
                                "type": "string",
                                "pattern": "^[0-9]{12}$"
                            },
                            "minItems": 1
                        }
                    },
                    "required": [
                        "models",
                        "accounts"
                    ],
                    "additionalProperties": false
                },
                "^(?!default$).+$": {
                    "type": "object",
                    "properties": {
                        "models": {
                            "type": "object",
                            "patternProperties": {
                                "^[a-zA-Z0-9.\\-:]+$": {
                                    "type": "object",
                                    "properties": {
                                        "rpm": {
                                            "type": "integer",
                                            "not": {
                                                "const": 0
                                            },
                                            "minimum": -1,
                                            "description": "Requests per minute (-1 for unlimited)"
                                        },
                                        "tpm": {
                                            "type": "integer",
                                            "not": {
                                                "const": 0
                                            },
                                            "minimum": -1,
                                            "description": "Tokens per minute (-1 for unlimited)"
                                        }
                                    },
                                    "required": [
                                        "rpm",
                                        "tpm"
                                    ],
                                    "additionalProperties": false
                                }
                            },
                            "additionalProperties": false
                        },
                        "accounts": {
                            "type": "array",
                            "items": {
                                "type": "string",
                                "pattern": "^[0-9]{12}$"
                            },
                            "minItems": 1
                        },
                        "name": {
                            "type": "string",
                            "description": "Human-readable name for the client"
                        }
                    },
                    "required": [
                        "models",
                        "accounts",
                        "name"
                    ],
                    "additionalProperties": false
                }
            },
            "additionalProperties": false
        },
        "account_limits": {
            "type": "object",
            "patternProperties": {
                "^[0-9]{12}$": {
                    "type": "object",
                    "patternProperties": {
                        "^[a-zA-Z0-9.\\-:]+$": {
                            "type": "object",
                            "properties": {
                                "rpm": {
                                    "type": "integer",
                                    "minimum": 1,
                                    "description": "Account-level requests per minute"
                                },
                                "tpm": {
                                    "type": "integer",
                                    "minimum": 1,
                                    "description": "Account-level tokens per minute"
                                }
                            },
                            "required": [
                                "rpm",
                                "tpm"
                            ],
                            "additionalProperties": false
                        }
                    },
                    "additionalProperties": false
                }
            },
            "additionalProperties": false
        }
    },
    "required": [
        "permissions"
    ],
    "additionalProperties": false
}
