# OAuth 2.0 Provider Configuration
# Use your enterprise OAuth provider or Auth0 for testing
OAUTH_JWKS_URL=https://your-oauth-provider.com/.well-known/jwks.json
OAUTH_ISSUER=https://your-oauth-provider.com/
JWT_AUDIENCE=bedrockproxygateway
JWT_ALLOWED_SCOPES=bedrockproxygateway:read,bedrockproxygateway:invoke,bedrockproxygateway:admin

# Application Configuration
ENVIRONMENT=dev
AWS_REGION=us-east-1
LOG_LEVEL=INFO

# AWS Configuration
SHARED_ROLE_NAME=bedrock-proxy-shared-role
SHARED_ACCOUNT_IDS=123456789012,234567890123
BEDROCK_RUNTIME_VPC_ENDPOINT_DNS=vpce-xxxxx.bedrock-runtime.us-east-1.vpce.amazonaws.com
STS_VPC_ENDPOINT_DNS=vpce-xxxxx.sts.us-east-1.vpce.amazonaws.com

# Caching Configuration
VALKEY_ENDPOINT=localhost
VALKEY_PORT=6379
GUARDRAIL_REFRESH_INTERVAL=300

# Observability Configuration
OTEL_SERVICE_NAME=bedrock-proxy-gateway
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_EXPORTER_OTLP_PROTOCOL=grpc
OTEL_EXPORTER_OTLP_INSECURE=true
OTEL_SDK_DISABLED=false
OTEL_RESOURCE_ATTRIBUTES=service.name=bedrock-proxy-gateway,deployment.environment=dev
