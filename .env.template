# =============================================================================
# Environment Configuration Template
# =============================================================================
#
# SETUP INSTRUCTIONS:
# 1. Copy this file to create environment-specific files:
#    - .env.dev   (for development environment)
#    - .env.test  (for test/QA environment)
#
# 2. Update the values in each file with your environment-specific settings
#
# 3. In the notebook, set ENVIRONMENT variable to 'dev', 'test'
#    to load the corresponding .env file
#
# Example:
#   cp .env.template .env.dev
#   # Edit .env.dev with your dev environment values
# =============================================================================

# AWS Configuration
AWS_PROFILE=default
AWS_REGION=us-east-1

# Gateway API URL (environment-specific endpoint)
# Example: https://bedrockproxygateway.example.com
GATEWAY_API_URL=https://your-gateway-url.com

# Secrets Manager secret ID containing OAuth client credentials
# The secret should contain: client_id, client_secret, token_url
GATEWAY_SECRET_ID=bedrock-gateway-dev-oauth-credentials

# mTLS Configuration (optional - only if backend has mTLS enabled)
# MTLS_CERT_PATH=/path/to/cert.pem
# MTLS_KEY_PATH=/path/to/key.pem
